# Domínio público (Traefik SSL)
DOMAIN=interativa.adrofecha.com.br

# Porta exposta no host
PORT=3001

# Node environment
NODE_ENV=production

# PostgreSQL — use o mesmo postgres que já está no seu servidor
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DB
# Exemplo usando o postgres já existente:
DATABASE_URL=postgresql://postgres:SUA_SENHA@192.168.0.110:5432/interativa

# Para desenvolvimento local (sem DATABASE_URL, usa SQLite automaticamente)
# Basta não definir DATABASE_URL e o sistema usa data/interativa.db
